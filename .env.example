# Copy to `.env` and fill. Never commit `.env`.
#
# Faz 1 MVP (`uvicorn app.main:app`) — minimum to be useful:
#   GROQ_API_KEY, T212_DEMO_API_KEY, T212_DEMO_API_SECRET, T212_BASE_URL
#   TELEGRAM_BOT_TOKEN (bot commands); leave TELEGRAM_WEBHOOK_URL empty for local polling.
# Optional: OLLAMA_* (LLM fallback), TELEGRAM_* (webhook/allow-list), LOG_LEVEL, FINNHUB_API_KEY (later features).
#
CEREBRAS_API_KEY=
# Faz 0 only: `python experiments/model_race/faz0_test.py` — requires `uv pip install cerebras-cloud-sdk`.
GROQ_API_KEY=
# Faz 0 Groq model: llama-3.3-70b-versatile (fixed in faz0_test.py).
# RAG embeddings: ollama pull nomic-embed-text (same OLLAMA_BASE_URL).
FINNHUB_API_KEY=
FMP_API_KEY=                 # financialmodelingprep.com (free tier)
# Trading 212 Public API: HTTP Basic Auth (Base64(key:secret)). Both required.
T212_DEMO_API_KEY=
T212_DEMO_API_SECRET=
# Demo: https://demo.trading212.com — Live: https://live.trading212.com
T212_BASE_URL=https://demo.trading212.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:14b

# ── Telegram Bot (Faz 1) ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=          # empty = polling mode (dev). Set full URL for webhook.
TELEGRAM_WEBHOOK_SECRET=       # required when TELEGRAM_WEBHOOK_URL is set (webhook rejects if empty)
TELEGRAM_ALLOWED_USER_IDS=     # comma-separated Telegram user IDs (required — empty = all commands denied)

# ── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# Faz 3: Paper Agent loop (set true to run forever)
PAPER_AGENT_ENABLED=false
# Paper risk (optional overrides)
PAPER_STARTING_NAV_USD=20000
# Supabase paper ledger display units (T212 mode: account currency comes from T212 API, e.g. EUR practice).
PAPER_ACCOUNT_CURRENCY=USD
PAPER_MAX_DRAWDOWN_PCT=30
PAPER_TECHNICAL_CACHE_TTL_SEC=90
# Paper execution: supabase (virtual PaperBroker ledger) | t212 (real market orders on T212; still mirrors rows to paper_trades)
PAPER_EXECUTION_BACKEND=supabase
# When PAPER_EXECUTION_BACKEND=t212: pass through to T212 market order extended-hours flag
PAPER_T212_EXTENDED_HOURS=true
# Pending fills (weekend / queued): background poller → paper_trades mirror when T212 reports fill
PAPER_T212_MIRROR_POLLER_ENABLED=true
# Seconds between ticks (min 15 enforced; history API is 6 req/min)
PAPER_T212_PENDING_POLL_SEC=90
# Each tick: sync GET /equity/orders so app-placed pending orders get mirrored on fill too
PAPER_T212_RECONCILE_EXTERNAL_ORDERS=true
# Mirror T212 cash + open positions into paper_account / paper_portfolio (same numbers as demo API)
PAPER_T212_SYNC_SUPABASE_LEDGER=true

# Faz 1.5-b: TOON prompt packing (requires: uv pip install -e ".[integrations]")
USE_TOON_PROMPTS=false

# Faz 5: browser UI at GET /ui (calls POST /ui/analyze). Public hosts: use TLS + proxy auth.
WEB_UI_ENABLED=false
# When set, all /internal/* routes require header: X-Internal-Api-Key: <same value>. Browser UI uses /ui/analyze (no key).
INTERNAL_API_KEY=

# ── Faz 1.5-d — Truth Social / Trump monitor (isteğe bağlı; token olmadan arka plan sessiz bekler)
TRUTH_SOCIAL_EMAIL=
TRUTH_SOCIAL_PASSWORD=
TRUTH_SOCIAL_ACCESS_TOKEN=
TRUTH_SOCIAL_BASE_URL=https://truthsocial.com
# sse (Mastodon event-stream, varsayılan) | websocket
TRUTH_SOCIAL_STREAM_TRANSPORT=sse
TRUMP_TRUTH_ACCOUNT_USERNAME=realDonaldTrump
TRUMP_IMPACT_THRESHOLD=5
# Set false on hosts whose egress IP gets 403'd by Truth Social Cloudflare WAF
# (Oracle/Hetzner datacenters). Disables WS + in-process puller; the
# /internal/trump/pull endpoint remains for ad-hoc/cron use.
TRUMP_MONITOR_ENABLED=true
# Llama 3.2 vision preview was deprecated on Groq (Oct 2025);
# Llama 4 Scout is the current production multimodal model (May 2026).
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Faz 2: RAG ve Kalıcı Hafıza (Supabase/pgvector) ────────────────
SUPABASE_URL=
SUPABASE_KEY=
# Zorunlu (trade_memories): asyncpg doğrudan Postgres URI. Yalnızca SUPABASE_URL/KEY (REST) RAG insert'lerini çalıştırmaz.
# Supabase: URI'de sslmode=require kullan (veya host *.supabase.com ise uygulama otomatik ekler).
# Örnek: postgresql://postgres.xxxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require
SUPABASE_DB_URL=
